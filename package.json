{
  "name": "gpt-image-cli",
  "version": "1.0.0",
  "description": "CLI for OpenAI gpt-image-2 generation and editing",
  "type": "module",
  "bin": { "gpt-image-cli": "./bin/gpt-image-cli.js" },
  "main": "dist/index.js",
  "files": ["bin/", "dist/", "skills/", "README.md"],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --outDir dist --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "mime": "^4.0.4",
    "openai": "^4.73.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "msw": "^2.4.0",
    "tsup": "^8.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
